@app.route('/api/wifi/connect', methods=['POST'])\
def connect_wifi():\
    data = request.json\
    ssid, pw, net_type = data.get('ssid'), data.get('password'), data.get('type')\
    \
    settings = DEFAULT_SETTINGS.copy()\
    if os.path.exists(SETTINGS_FILE):\
        with open(SETTINGS_FILE, 'r') as f: settings.update(json.load(f))\
    \
    if "net_profiles" not in settings: settings["net_profiles"] = \{\}\
    if "net_passwords" not in settings: settings["net_passwords"] = \{\}\
    \
    settings["net_profiles"][ssid] = net_type\
    if pw: settings["net_passwords"][ssid] = pw\
    \
    with open(SETTINGS_FILE, 'w') as f: json.dump(settings, f)\
\
    try:\
        subprocess.run(['sudo', 'nmcli', 'connection', 'delete', ssid], capture_output=True)\
        res = subprocess.run(['sudo', 'nmcli', 'dev', 'wifi', 'connect', ssid, 'password', pw], capture_output=True, text=True, timeout=25)\
        \
        if res.returncode != 0:\
            subprocess.run(['sudo', 'nmcli', 'connection', 'add', 'type', 'wifi', 'ifname', 'wlan0', 'con-name', ssid, 'ssid', ssid, 'wifi-sec.key-mgmt', 'wpa-psk', 'wifi-sec.psk', pw], capture_output=True)\
            res2 = subprocess.run(['sudo', 'nmcli', 'connection', 'up', ssid], capture_output=True, text=True, timeout=25)\
            if res2.returncode == 0:\
                subprocess.run(['sudo', 'nmcli', 'connection', 'modify', ssid, 'connection.autoconnect', 'yes'])\
                return jsonify(\{"status": "success", "msg": f"Forced connection to \{ssid\} successfully!"\})\
            else:\
                err = res2.stderr.strip() if res2.stderr else res2.stdout.strip()\
                return jsonify(\{"status": "error", "msg": f"Manual Override Failed: \{err\}"\})\
        else:\
            subprocess.run(['sudo', 'nmcli', 'connection', 'modify', ssid, 'connection.autoconnect', 'yes'])\
            return jsonify(\{"status": "success", "msg": f"Connected to \{ssid\} successfully!"\})\
    except subprocess.TimeoutExpired:\
        return jsonify(\{"status": "error", "msg": "Failed: Connection timed out. Check hotspot compatibility settings."\})\
    except Exception as e:\
        return jsonify(\{"status": "error", "msg": f"Internal Error: \{str(e)\}"\})\
