                </div>\
                <div class="modal-row" style="margin-top: 5px;">\
                    <span>STEER USB:</span>\
                    <select id="set_steer_port" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:5px; border-radius:5px; width: 55%; margin-left: 10px;"></select>\
                </div>\
                <button id="btn_rescan_usb" class="modal-btn" style="border-color:#0af; color:#0af; margin-top:10px; width:100%; margin-bottom: 15px;" onclick="forceUSBRescan()">FORCE RE-SCAN USBs</button>\
                <hr>\
\
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">DRIVE CONTROLLER (UNO)</div>\
                <div class="modal-row" style="margin-bottom: 10px;">\
                    <span>FAILSAFE SECONDS:<br><i style="font-size:10px; color:#aaa;">(Prevents instant fwd/rev switching)</i></span>\
                    <select id="set_failsafe_sec" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:5px; border-radius:5px; width: 40%; margin-left: 10px;">\
                        <option value="0">0 SECONDS</option>\
                        <option value="0.5">0.5 SECONDS</option>\
                        <option value="1">1 SECOND</option>\
                        <option value="1.5">1.5 SECONDS</option>\
                        <option value="2">2 SECONDS</option>\
                        <option value="2.5">2.5 SECONDS</option>\
                        <option value="3">3 SECONDS</option>\
                        <option value="3.5">3.5 SECONDS</option>\
                        <option value="4">4 SECONDS</option>\
                        <option value="4.5">4.5 SECONDS</option>\
                        <option value="5">5 SECONDS</option>\
                    </select>\
                </div>\
                \
                <div class="modal-row">\
                    <span>RUNNING TIME:</span>\
                    <b id="ui_up_drive" style="color:#0f0;">--</b>\
                </div>\
                <button class="modal-btn" style="width:100%; border-color:#f00; color:#f00; margin-top:10px; background:rgba(255,0,0,0.1);" onclick="restartMCU('drive')">RESTART ESP_DRIVE</button>\
\
                <hr style="margin: 20px 0;">\
                \
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">STEER CONTROLLER (ESP8266)</div>\
                \
                <div class="modal-row" style="margin-bottom: 10px;">\
                    <span>RACING STEER MODE:<br><i style="font-size:10px; color:#aaa;">(Prevents rollover at high GPS speeds)</i></span>\
                    <select id="set_racing" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:5px; border-radius:5px; width: 40%;">\
                        <option value="false">DISABLED</option><option value="true">ENABLED</option>\
                    </select>\
                </div>\
\
                <div class="modal-row" style="margin-bottom: 10px;">\
                    <span>CENTERING TIME (SEC):<br><i style="font-size:10px; color:#aaa;">(0 to disable auto-centering failsafe)</i></span>\
                    <div style="width:50%; display:flex; align-items:center;">\
                        <input type="range" class="std-slider" id="set_autoc" min="0" max="10" step="0.1" oninput="document.getElementById('sv_autoc').innerText=this.value+'s'" style="margin-top:0;">\
                        <span class="set-val" id="sv_autoc" style="margin-left: 5px;">0.0s</span>\
                    </div>\
                </div>\
\
                <div class="modal-row">\
                    <span>RUNNING TIME:</span>\
                    <b id="ui_up_steer" style="color:#0f0;">--</b>\
                </div>\
                \
                <button class="modal-btn" style="width:100%; border-color:#f00; color:#f00; margin-top:10px; background:rgba(255,0,0,0.1);" onclick="restartMCU('steer')">RESTART ESP_STEER</button>\
\
                <div class="btn-row" style="margin-top: 15px;">\
                    <button class="modal-btn" style="background: rgba(0,255,0,0.3);" onclick="saveSettings()">SAVE MCU SETTINGS</button>\
                </div>\
            </div>\
\
            <div id="tab_network" class="tab-body">\
                <div style="background: rgba(0,0,0,0.5); padding:10px; border:1px solid #0f0; border-radius:5px; margin-bottom:15px;">\
                    <div>CURRENT IP: <b id="ui_ip" style="color:#fff;">Loading...</b></div>\
                    <div>TUNNEL STATUS: <b id="ui_pinggy" style="color:#fff;">Waiting...</b></div>\
