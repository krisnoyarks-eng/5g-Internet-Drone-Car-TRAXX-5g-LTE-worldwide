                        <option value="9">9. Bicycle Bell</option>\
                        <option value="10">10. Airhorn</option>\
                    </select>\
                </div>\
                <hr style="margin: 15px 0;">\
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">BLUETOOTH SCANNER</div>\
                <div style="font-size:10px; color:#aaa; margin-bottom:10px; text-align:center;">Ensure your Mac is disconnected before scanning.</div>\
                <button class="modal-btn" style="width:100%; border-color:#0af; color:#0af; background:rgba(0,170,255,0.1);" onclick="scanBT()">
\f1 \uc0\u55357 \u56589 
\f0  SCAN FOR BLUETOOTH SPEAKERS</button>\
                <div id="bt_list" style="margin-top:15px; max-height:250px; overflow-y:auto;"></div>\
                \
                <div class="btn-row" style="margin-top: 15px;">\
                    <button class="modal-btn" style="background: rgba(0,255,0,0.3);" onclick="saveSettings()">SAVE AUDIO SETTINGS</button>\
                </div>\
            </div>\
            \
            <div id="tab_personal_tunnel" class="tab-body">\
                <div style="background: rgba(0,255,0,0.15); border: 1px solid #0f0; border-radius: 8px; padding: 15px; text-align: center; font-weight: bold; margin-bottom: 15px;">\
                    <div style="font-size:12px; color:#aaa; margin-bottom:5px;">THIS DRONE'S FLEET PORT:</div>\
                    <input type="number" id="set_fleet_port" value="8585" min="7001" max="9000" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:10px; border-radius:5px; width: 60%; font-size:24px; text-align:center; font-weight:bold; letter-spacing: 2px; display:block; margin: 0 auto;">\
                    <div style="font-size:10px; color:#aaa; margin-top:5px;">Set to 8585 by default. Edit and click START FLEET TUNNEL to save.</div>\
                </div>\
\
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">FLEET SERVER CONFIG</div>\
                <div class="modal-row">\
                    <span>SERVER IP/DOMAIN:</span>\
                    <input type="text" id="set_frp_ip" placeholder="10.0.0.222" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:5px; border-radius:5px; width: 60%; margin-left: 10px;">\
                </div>\
                <div style="font-size:10px; color:#aaa; margin-top:10px; text-align:center;">\
                    Once enabled, drive this car by going to: <br>\
                    <b style="color:#0f0;" id="disp_full_link">http://SERVER_IP:PORT</b>\
                </div>\
                <div class="btn-row" style="margin-top: 20px;">\
                    <button class="modal-btn" style="background: rgba(0,255,0,0.3);" onclick="saveTunnelSettings('frp')">START FLEET TUNNEL</button>\
                </div>\
            </div>\
\
        </div>\
    </div>\
\
  <script>\
        document.addEventListener('dblclick', function(e) \{ e.preventDefault(); \}, \{ passive: false \});\
        document.addEventListener('contextmenu', event => event.preventDefault());\
        \
        let MAX_LEFT_PERCENT = 100, MAX_RIGHT_PERCENT = 100;\
        let currentFwdLimit = 1, currentRevLimit = 1;\
        let isSteering = false, isDriving = false;\
        let absoluteCenterOffset = 90.0, steerTimeout;\
        let unitSystem = 'metric', batt_count = 1, batt_mah = 5800;\
        \
        let currentFailsafeMs = 3000; \
\
        let map = null, marker = null;\
        let lastLat = 0, lastLon = 0; \
        let globalFleetPort = 8585;\
        let loadCheckInterval;\
        \
        try \{\
            map = map = L.map('map', \{zoomControl: false, attributionControl: false\}).setView([0, 0], 16);\
            L.tileLayer('https://\{s\}.tile.openstreetmap.org/\{z\}/\{x\}/\{y\}.png').addTo(map);\
            marker = L.circleMarker([0, 0], \{color: '#0f0', fillColor: '#0f0', fillOpacity: 1, radius: 6\}).addTo(map);\
        \} catch(e) \{\}\
        \
        window.onload = function() \{\
            if (!sessionStorage.getItem('legal_agreed')) \{\
                document.getElementById('legal-modal').style.display = 'flex';\
            \} else \{\
                initiateLoadingSequence();\
            \}\
        \};\
\
        function acceptLegal() \{\
            sessionStorage.setItem('legal_agreed', 'true');\
            document.getElementById('legal-modal').style.display = 'none';\
            initiateLoadingSequence();\
        \}\
\
        function initiateLoadingSequence() \{\
            if (!sessionStorage.getItem('usb_checked')) \{\
                document.getElementById('loading-modal').style.display = 'flex';\
                loadCheckInterval = setInterval(() => \{\
                    fetch('/data', \{ cache: "no-store" \}).then(r=>r.json()).then(d => \{\
                        if (d.drive_port_name !== "--" && d.drive_port_name !== "Disconnected" && d.steer_port_name !== "--" && d.steer_port_name !== "Disconnected") \{\
                            clearInterval(loadCheckInterval);\
                            skipLoading();\
                        \}\
                    \}).catch(()=>\{\});\
                \}, 1500);\
            \} else \{\
                checkStartup();\
            \}\
        \}\
\
        function skipLoading() \{\
            clearInterval(loadCheckInterval);\
            sessionStorage.setItem('usb_checked', 'true');\
            document.getElementById('loading-modal').style.display = 'none';\
            checkStartup();\
        \}\
\
        function checkStartup() \{\
            if (!sessionStorage.getItem('startup_cal_done')) \{\
                document.getElementById('startup-modal').style.display = 'flex';\
            \}\
            fetch('/api/settings', \{ cache: "no-store" \}).then(r => r.json()).then(s => \{\
                currentFwdLimit = parseInt(s.fwd_def); currentRevLimit = parseInt(s.rev_def);\
                document.getElementById('fwd_lbl').innerText = 'FWD ' + currentFwdLimit;\
                document.getElementById('rev_lbl').innerText = 'REV ' + currentRevLimit;\
                absoluteCenterOffset = parseFloat(s.center_offset) || 90.0;\
                MAX_LEFT_PERCENT = parseInt(s.max_l); MAX_RIGHT_PERCENT = parseInt(s.max_r);\
                document.getElementById('ui_sens').style.opacity = parseInt(s.op_sens) / 100.0;\
                document.getElementById('ui_ctrl_l').style.opacity = parseInt(s.op_ctrl) / 100.0;\
                document.getElementById('ui_ctrl_r').style.opacity = parseInt(s.op_ctrl) / 100.0;\
                unitSystem = s.unit_system || 'metric';\
                batt_count = parseInt(s.batt_count || 1); batt_mah = parseInt(s.batt_mah || 5800);\
                \
                document.getElementById('set_frp_ip').value = s.frp_ip || "";\
                document.getElementById('set_fleet_port').value = s.fleet_port || 8585;\
                \
                document.getElementById('set_pi_password').value = s.pi_password || "drone786@@";\
                document.getElementById('set_gui_enabled').value = s.gui_enabled ? "true" : "false";\
                document.getElementById('set_horn_type').value = s.horn_type || "1";\
                \
                let fs = s.failsafe_sec !== undefined ? parseFloat(s.failsafe_sec) : 3.0;\
                document.getElementById('set_failsafe_sec').value = fs;\
                currentFailsafeMs = fs * 1000;\
            \});\
        \}\
\
        function toggleGUI(val) \{\
            let state = val === "true" ? "on" : "off";\
            fetch('/api/toggle_gui', \{ method: 'POST', headers: \{'Content-Type': 'application/json'\}, body: JSON.stringify(\{state: state\})\});\
        \}\
        \
        function toggleAudio(btn) \{\
            let aud = document.getElementById("cam_audio");\
            if (aud.paused || !aud.src || aud.src === window.location.href) \{\
                aud.src = window.location.origin + "/audio/";\
                aud.load();\
                let p = aud.play();\
                if (p !== undefined) \{\
                    p.then(() => \{ \
                        btn.innerText = "
\f1 \uc0\u55357 \u56586 
\f0 "; \
                        btn.style.color = "#0f0";\
                    \}).catch(e => \{\
                        console.log(e);\
                        alert("Browser security blocked autoplay. Tap anywhere on the empty black screen, then tap this icon again.");\
                    \});\
                \}\
            \} else \{\
                aud.pause();\
                aud.src = "";\
                btn.innerText = "
\f1 \uc0\u55357 \u56583 
\f0 ";\
                btn.style.color = "";\
            \}\
        \}\
\
        function restartMCU(target) \{\
            if(confirm("Are you sure you want to hard reset the " + target.toUpperCase() + " Microcontroller?")) \{\
                fetch('/api/restart_mcu/' + target, \{method:'POST'\});\
            \}\
        \}\
\
        function restartPilot() \{\
            if(confirm("Restart the Drone Brain? The HUD will disconnect for 10 seconds while it clears USB memory and re-binds.")) \{\
                fetch("/api/restart_pilot", \{method:"POST"\}).catch(()=>\{\});\
                setTimeout(() => window.location.reload(), 10000);\
            \}\
        \}\
\
        function switchTab(id, btn) \{\
            document.querySelectorAll('.tab-body').forEach(el => el.classList.remove('active'));\
            document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));\
            document.getElementById('tab_' + id).classList.add('active');\
            btn.classList.add('active');\
            if(id === 'network') scanWifi();\
        \}\
\
        function submitStartupCal() \{\
            let val = document.getElementById('startup_calib_pct').value;\
            if (val.trim() !== "") fetch('/drive/set_cal?p='+parseInt(val)).catch(()=>\{\});\
            document.getElementById('startup-modal').style.display = 'none';\
            sessionStorage.setItem('startup_cal_done', 'true');\
        \}\
\
        function openModal() \{\
            fetch('/api/ports', \{ cache: "no-store" \}).then(r => r.json()).then(ports => \{\
                let dSelect = document.getElementById('set_drive_port');\
                let sSelect = document.getElementById('set_steer_port');\
                dSelect.innerHTML = '<option value="auto">AUTO DETECT</option>';\
                sSelect.innerHTML = '<option value="auto">AUTO DETECT</option>';\
                ports.forEach(p => \{\
                    dSelect.innerHTML += `<option value="$\{p\}">$\{p\}</option>`;\
                    sSelect.innerHTML += `<option value="$\{p\}">$\{p\}</option>`;\
                \});\
                fetch('/api/settings', \{ cache: "no-store" \}).then(r => r.json()).then(s => \{\
                    if (s.drive_port && ports.includes(s.drive_port)) dSelect.value = s.drive_port;\
                    if (s.steer_port && ports.includes(s.steer_port)) sSelect.value = s.steer_port;\
                    document.getElementById('set_fwd').value = s.fwd_def; document.getElementById('sv_fwd').innerText = s.fwd_def;\
                    document.getElementById('set_rev').value = s.rev_def; document.getElementById('sv_rev').innerText = s.rev_def;\
                    document.getElementById('set_abs_l').value = s.abs_min_l || 50.0; document.getElementById('sv_abs_l').innerText = s.abs_min_l || 50.0;\
                    document.getElementById('set_abs_r').value = s.abs_max_r || 130.0; document.getElementById('sv_abs_r').innerText = s.abs_max_r || 130.0;\
                    document.getElementById('set_center').value = s.center_offset || 90.0; document.getElementById('sv_center').innerText = s.center_offset || 90.0;\
                    document.getElementById('set_max_l').value = s.max_l; document.getElementById('sv_max_l').innerText = s.max_l + '%';\
                    document.getElementById('set_max_r').value = s.max_r; document.getElementById('sv_max_r').innerText = s.max_r + '%';\
                    document.getElementById('set_op_sens').value = s.op_sens; document.getElementById('sv_op_sens').innerText = s.op_sens + '%';\
                    document.getElementById('set_op_ctrl').value = s.op_ctrl; document.getElementById('sv_op_ctrl').innerText = s.op_ctrl + '%';\
                    document.getElementById('set_unit').value = s.unit_system || 'metric';\
                    document.getElementById('set_b_type').value = s.batt_type || 'lipo';\
                    document.getElementById('set_b_count').value = s.batt_count || 1;\
                    document.getElementById('set_b_mah').value = s.batt_mah || 5800;\
                    \
                    document.getElementById('set_racing').value = s.racing_mode ? "true" : "false";\
                    document.getElementById('set_autoc').value = s.auto_center_sec || 0.0;\
                    document.getElementById('sv_autoc').innerText = (s.auto_center_sec || 0.0) + 's';\
                    \
                    document.getElementById('set_pi_password').value = s.pi_password || "drone786@@";\
                    document.getElementById('set_gui_enabled').value = s.gui_enabled ? "true" : "false";\
                    document.getElementById('set_horn_type').value = s.horn_type || "1";\
                    \
                    let fs = s.failsafe_sec !== undefined ? parseFloat(s.failsafe_sec) : 3.0;\
                    document.getElementById('set_failsafe_sec').value = fs;\
\
                    document.getElementById('settings-modal').style.display = 'flex';\
                \});\
            \});\
        \}\
        \
        function closeModal() \{ \
            document.getElementById('settings-modal').style.display = 'none'; \
            fetch('/steer/set_center?v='+absoluteCenterOffset).catch(()=>\{\});\
        \}\
\
        function testCenterOffset(val) \{\
            document.getElementById('sv_center').innerText = val;\
            clearTimeout(steerTimeout);\
            steerTimeout = setTimeout(() => \{\
                fetch('/steer/set_center?v=' + val).catch(()=>\{\});\
            \}, 50); \
        \}\
\
        async function forceUSBRescan() \{\
            let btn = document.getElementById('btn_rescan_usb');\
            btn.innerText = "NUKING PORTS & RE-SCANNING...";\
            btn.style.opacity = "0.5";\
            document.getElementById('ui_dp').innerText = "SCANNING...";\
            document.getElementById('ui_dp').style.color = "yellow";\
            document.getElementById('ui_sp').innerText = "SCANNING...";\
            document.getElementById('ui_sp').style.color = "yellow";\
\
            await fetch('/api/rescan_usb', \{method: 'POST'\});\
            \
            setTimeout(() => \{\
                btn.innerText = "FORCE RE-SCAN USBs";\
                btn.style.opacity = "1";\
                document.getElementById('ui_dp').style.color = "#0af";\
                document.getElementById('ui_sp').style.color = "#0af";\
                \
                fetch('/data').then(r => r.json()).then(d => \{\
                    if(d.drive_port_name && d.drive_port_name !== "Disconnected") document.getElementById('set_drive_port').value = d.drive_port_name;\
                    if(d.steer_port_name && d.steer_port_name !== "Disconnected") document.getElementById('set_steer_port').value = d.steer_port_name;\
                \}).catch(()=>\{\});\
            \}, 4000);\
        \}\
\
        function scanWifi() \{\
            let list = document.getElementById('wifi_list');\
            list.innerHTML = "<i>Scanning airspace...</i>";\
            \
            Promise.all([\
                fetch('/api/wifi/scan').then(r => r.json()),\
                fetch('/api/settings', \{ cache: "no-store" \}).then(r => r.json())\
            ]).then(([nets, s]) => \{\
                list.innerHTML = "";\
                let idx = 0;\
                let savedPass = s.net_passwords || \{\};\
                let savedType = s.net_profiles || \{\};\
                \
                nets.forEach(n => \{\
                    let safeSsid = n.ssid.replace(/'/g, "\\\\'"); \
                    let prefillPw = savedPass[n.ssid] || "";\
                    let type = savedType[n.ssid] || "outside";\
                    let selOut = type === 'outside' ? 'selected' : '';\
                    let selHome = type === 'home' ? 'selected' : '';\
                    \
                    list.innerHTML += `\
                        <div class="net-card">\
                            <div class="net-title">$\{n.ssid\} (Signal: $\{n.signal\})</div>\
                            <input type="text" id="pw_$\{idx\}" value="$\{prefillPw\}" placeholder="Password (if any)" style="width:100%; padding:8px; margin-bottom:5px; background:#000; color:#0f0; border:1px solid #0f0; outline:none;">\
                            <select id="type_$\{idx\}" style="width:100%; padding:8px; background:#000; color:#0f0; border:1px solid #0f0; margin-bottom:5px; outline:none;">\
                                <option value="outside" $\{selOut\}>OUTSIDE (Use Active Tunnel)</option>\
                                <option value="home" $\{selHome\}>HOME (Disable Tunnels, Use Local IP)</option>\
                            </select>\
                            <button id="btn_$\{idx\}" class="modal-btn" style="background:rgba(0,255,0,0.2);" onclick="connectWifi('$\{safeSsid\}', $\{idx\}, this)">CONNECT & SAVE</button>\
                        </div>`;\
                    idx++;\
                \});\
            \}).catch(() => \{ list.innerHTML = "<i>Scan failed.</i>"; \});\
        \}\
\
        async function connectWifi(ssid, idx, btn) \{\
            let pw = document.getElementById('pw_'+idx).value;\
            let type = document.getElementById('type_'+idx).value;\
            \
            let origText = btn.innerText;\
            btn.innerText = "CONNECTING... PLEASE WAIT";\
            btn.style.opacity = "0.5";\
            btn.disabled = true;\
\
            try \{\
                let res = await fetch('/api/wifi/connect', \{\
                    method: 'POST', headers: \{ 'Content-Type': 'application/json' \},\
                    body: JSON.stringify(\{ssid: ssid, password: pw, type: type\})\
                \});\
                let data = await res.json();\
                alert(data.msg);\
                \
            \} catch(e) \{\
                alert("Communication Error: Could not reach Drone Brain.");\
            \}\
\
            btn.innerText = origText;\
            btn.style.opacity = "1";\
            btn.disabled = false;\
        \}\
\
        function scanBT() \{\
            let list = document.getElementById('bt_list');\
            list.innerHTML = "<i>Scanning (8 seconds)...</i>";\
            fetch('/api/bt/scan').then(r=>r.json()).then(devs=>\{\
                list.innerHTML = "";\
                if(devs.length===0) \{ list.innerHTML="<i>No devices found. Is it still connected to your Mac?</i>"; return; \}\
                devs.forEach((d,i) => \{\
                    list.innerHTML += `<div class="net-card"><div class="net-title" style="color:#0af;">$\{d.name\}</div><div style="font-size:10px;color:#aaa;margin-bottom:8px;">MAC: $\{d.mac\}</div><button class="modal-btn" style="background:rgba(0,255,0,0.2);width:100%;" onclick="connectBT('$\{d.mac\}', this)">CONNECT & SAVE</button></div>`;\
                \});\
            \}).catch(()=>list.innerHTML="<i>Scan failed.</i>");\
        \}\
\
        function connectBT(mac, btn) \{\
            btn.innerText = "PAIRING & ROUTING AUDIO..."; btn.disabled = true; btn.style.opacity = "0.5";\
            fetch('/api/bt/connect', \{method:'POST', headers:\{'Content-Type':'application/json'\}, body:JSON.stringify(\{mac:mac\})\})\
            .then(()=>\{ setTimeout(()=>\{btn.innerText="CONNECTED & SAVED!"; btn.style.background="rgba(0,255,0,0.6)"; btn.style.opacity="1";\}, 4500); \});\
        \}\
\
        async function saveTunnelSettings(type) \{\
            let payload = \{\
                active_tunnel: type,\
                frp_ip: document.getElementById('set_frp_ip').value,\
                fleet_port: parseInt(document.getElementById('set_fleet_port').value) || 8585\
            \};\
            \
            await fetch('/api/settings', \{ method: 'POST', headers: \{ 'Content-Type': 'application/json' \}, body: JSON.stringify(payload) \});\
            alert(type.toUpperCase() + " Tunnel Selected & Saved!");\
            document.getElementById('settings-modal').style.display = 'none';\
        \}\
        \
        async function saveSettings() \{\
            let centerVal = parseFloat(document.getElementById('set_center').value);\
            absoluteCenterOffset = centerVal;\
            let payload = \{\
                fwd_def: document.getElementById('set_fwd').value,\
                rev_def: document.getElementById('set_rev').value,\
                failsafe_sec: parseFloat(document.getElementById('set_failsafe_sec').value),\
                abs_min_l: document.getElementById('set_abs_l').value,\
                abs_max_r: document.getElementById('set_abs_r').value,\
                center_offset: centerVal,\
                max_l: document.getElementById('set_max_l').value,\
                max_r: document.getElementById('set_max_r').value,\
                op_sens: document.getElementById('set_op_sens').value,\
                op_ctrl: document.getElementById('set_op_ctrl').value,\
                unit_system: document.getElementById('set_unit').value,\
                batt_type: document.getElementById('set_b_type').value,\
                batt_count: document.getElementById('set_b_count').value,\
                batt_mah: document.getElementById('set_b_mah').value,\
                drive_port: document.getElementById('set_drive_port').value,\
                steer_port: document.getElementById('set_steer_port').value,\
                racing_mode: document.getElementById('set_racing').value === "true",\
                auto_center_sec: parseFloat(document.getElementById('set_autoc').value),\
                pi_password: document.getElementById('set_pi_password').value,\
                gui_enabled: document.getElementById('set_gui_enabled').value === "true",\
                horn_type: document.getElementById('set_horn_type').value\
            \};\
            \
            let espTypeVal = (payload.batt_type === 'nimh') ? 1 : 0;\
            \
            await Promise.all([\
                fetch('/api/rescan_usb', \{method: 'POST'\}),\
                fetch('/drive/set_limits?f='+payload.fwd_def+'&r='+payload.rev_def).catch(()=>\{\}),\
                fetch('/drive/set_fs?v='+payload.failsafe_sec).catch(()=>\{\}),\
                fetch('/drive/set_bcfg?t='+espTypeVal).catch(()=>\{\}), \
                fetch('/drive/set_bcnt?v='+payload.batt_count).catch(()=>\{\}),\
                fetch('/drive/set_bmah?v='+payload.batt_mah).catch(()=>\{\}),\
\
                fetch('/steer/set_walls?l='+payload.abs_min_l+'&r='+payload.abs_max_r).catch(()=>\{\}),\
                fetch('/steer/set_center?v='+centerVal).catch(()=>\{\}),\
                fetch('/api/settings', \{ method: 'POST', headers: \{ 'Content-Type': 'application/json' \}, body: JSON.stringify(payload) \}).catch(()=>\{\})\
            ]);\
            document.getElementById('settings-modal').style.display = 'none';\
            window.location.reload(true);\
        \}\
\
        window.addEventListener('touchend', e => \{ if(e.touches.length === 0 && document.getElementById('settings-modal').style.display !== 'flex') \{ resetSteer(); resetDrive(); \}\});\
        window.addEventListener('mouseup', e => \{ if(document.getElementById('settings-modal').style.display !== 'flex') \{ resetSteer(); resetDrive(); \}\});\
\
        let targetSteerVal = 0; let steerInterval = null;\
        function updateSteerTarget(v) \{ targetSteerVal = parseFloat(v); \}\
        function startSteer() \{\
            if (!isSteering) \{\
                isSteering = true;\
                steerInterval = setInterval(() => \{\
                    let val = targetSteerVal;\
                    if (val < 0) val = val * (MAX_LEFT_PERCENT / 100.0); else if (val > 0) val = val * (MAX_RIGHT_PERCENT / 100.0);\
                    fetch('/steer/a_steer?v='+val).catch(()=>\{\});\
                \}, 100); \
            \}\
        \}\
        function resetSteer() \{ \
            isSteering = false; targetSteerVal = 0; document.getElementById('steer_slider').value = 0;\
            clearInterval(steerInterval); steerInterval = null;\
            fetch('/steer/a_steer?v=0').catch(()=>\{\}); \
        \}\
\
        let targetRawVal = 0; let driveInterval = null; let lastDir = null; let switchBlockUntil = 0;\
        \
        function processDrive() \{\
            let now = Date.now();\
            if (targetRawVal === 0) \{ \
                if (lastDir !== null && switchBlockUntil === 0 && currentFailsafeMs > 0) switchBlockUntil = now + currentFailsafeMs; \
            \} else \{\
                let intendedDir = targetRawVal > 0 ? 'a' : 'b';\
                if (lastDir === null) lastDir = intendedDir;\
                if (intendedDir !== lastDir) \{\
                    if (switchBlockUntil === 0 && currentFailsafeMs > 0) switchBlockUntil = now + currentFailsafeMs; \
                    if (now < switchBlockUntil) return; else \{ lastDir = intendedDir; switchBlockUntil = 0; \}\
                \} else \{ switchBlockUntil = 0; lastDir = intendedDir; \}\
                let limit = targetRawVal > 0 ? currentFwdLimit : currentRevLimit;\
                let speed = Math.max(1, Math.round((Math.abs(targetRawVal) / 10) * limit));\
                fetch('/drive/' + intendedDir + speed).catch(()=>\{\});\
            \}\
        \}\
        \
        function sendDrive(v) \{ isDriving = true; targetRawVal = parseInt(v); if (!driveInterval) driveInterval = setInterval(processDrive, 200); \}\
        \
        function resetDrive() \{ \
            isDriving = false; targetRawVal = 0; \
            if(document.getElementById('fwd_slider')) document.getElementById('fwd_slider').value = 0;\
            if(document.getElementById('rev_slider')) document.getElementById('rev_slider').value = 0;\
            clearInterval(driveInterval); driveInterval = null;\
            lastDir = null;\
            switchBlockUntil = 0;\
        \}\
\
        setInterval(() => \{\
            let pingStart = Date.now();\
            fetch('/data?t=' + pingStart, \{ cache: "no-store" \}).then(r => r.json()).then(data => \{\
                \
                let latency = Date.now() - pingStart;\
                let pingEl = document.getElementById('ui_ping');\
                pingEl.innerText = latency + 'ms';\
                if(latency > 300) pingEl.style.color = 'orange';\
                if(latency > 600) pingEl.style.color = 'red';\
                if(latency <= 300) pingEl.style.color = '#0f0';\
\
                document.getElementById('vD').innerText = data.volts.toFixed(1) + 'V';\
                document.getElementById('aD').innerText = data.amps.toFixed(1) + 'A';\
                if (data.amps > 0.2) \{\
                    let totalMah = batt_count * batt_mah; let remainingMah = totalMah * (data.pct / 100.0);\
                    let hoursLeft = (remainingMah / 1000.0) / data.amps;\
                    document.getElementById('tD').innerText = '(' + Math.max(0, Math.round(hoursLeft * 60)) + 'm left)';\
                \} else document.getElementById('tD').innerText = '(--m left)';\
\
                document.getElementById('sN').innerText = data.ssid;\
                document.getElementById('sL').style.width = data.sig_pct + '%';\
                document.getElementById('pD').innerText = data.pct + '%';\
                document.getElementById('bL').style.width = data.pct + '%';\
                \
                globalFleetPort = data.fleet_port || 8585;\
                let s_ip = document.getElementById('set_frp_ip').value || "YOUR_SERVER_IP";\
