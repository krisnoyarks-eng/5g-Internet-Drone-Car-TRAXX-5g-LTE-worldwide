    while True:\
        process = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)\
        try:\
            while True:\
                data = process.stdout.read(4096)\
                if not data: break\
                yield data\
        except Exception: pass\
        finally:\
            process.terminate()\
            process.wait()\
        time.sleep(1)\
