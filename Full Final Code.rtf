        #minimap_container \{ position: fixed; bottom: 80px; right: 20px; width: 150px; height: 150px; border-radius: 50%; border: 3px solid #0f0; overflow: hidden; z-index: 10; pointer-events: none; opacity: 0.8; \}\
        #map \{ width: 100%; height: 100%; \}\
        .leaflet-control-container \{ display: none !important; \}\
        \
        .bottom-stats \{ position: fixed; bottom: 10px; left: 50%; transform: translateX(-50%); display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; background: rgba(0,0,0,0.6); padding: 8px 20px; border-radius: 20px; z-index: 10; font-size: 14px; border: 1px solid #0f0; width: 95%; max-width: 800px; \}\
\
        @keyframes spin \{ 100% \{ transform: rotate(360deg); \} \}\
    </style>\
</head>\
<body>\
    <div class="vid-container">\
        <audio id="cam_audio" preload="none"></audio>\
        <img src="/cam/" style="width: 100%; height: 100%; object-fit: cover; pointer-events: none;">\
    </div>\
    \
    <div class="overlay-stats" id="ui_sens">\
        <div class="clickable" onclick="openModal()" style="font-size: 18px; padding-right:15px;">
\f1 \uc0\u9881 \u65039 
\f0 </div>\
        <div class="clickable" onclick="toggleAudio(this)" style="font-size: 18px; padding-right:15px;" title="Toggle Camera Mic">
\f1 \uc0\u55357 \u56583 
\f0 </div>\
        <div>PING: <span id="ui_ping" style="color:#0f0;">--ms</span></div>\
        <div id="vD">--V</div>\
        <div><span id="aD">--A</span> <span id="tD" style="color:#aaa; font-size:11px; margin-left:5px;">(--m left)</span></div>\
        <div class="clickable" onclick="location.href='/wifi_setup'">\
            <span id="sN" style="color: #0af;">--</span> \
            <div class="icon-outline" style="border-color: #0af;"><div id="sL" class="fill" style="background: #0af;"></div></div>\
        </div>\
        <div><span id="pD">--%</span><div class="icon-outline" style="position:relative;"><div id="bL" class="fill"></div><div style="position:absolute;right:-4px;top:2px;width:3px;height:6px;background:#0f0;"></div></div></div>\
    </div>\
\
    <div class="joystick-left" id="ui_ctrl_l">\
        <span id="fwd_lbl">FWD</span>\
        <div class="vert-wrapper">\
            <input type="range" class="fwd-slider" id="fwd_slider" min="0" max="10" value="0" oninput="sendDrive(this.value); document.getElementById('rev_slider').value=0;" ontouchstart="isDriving=true" onmousedown="isDriving=true" ontouchend="resetDrive()" onmouseup="resetDrive()" ontouchcancel="resetDrive()" onmouseleave="resetDrive()">\
        </div>\
        <div class="vert-wrapper">\
            <input type="range" class="rev-slider" id="rev_slider" min="0" max="10" value="0" oninput="sendDrive(-this.value); document.getElementById('fwd_slider').value=0;" ontouchstart="isDriving=true" onmousedown="isDriving=true" ontouchend="resetDrive()" onmouseup="resetDrive()" ontouchcancel="resetDrive()" onmouseleave="resetDrive()">\
        </div>\
        <span id="rev_lbl">REV</span>\
    </div>\
\
    <div class="joystick-right" id="ui_ctrl_r">\
        <div style="display: flex; align-items: center; gap: 15px;">\
            <span>L</span>\
            <input type="range" id="steer_slider" min="-1" max="1" step="0.05" value="0" oninput="updateSteerTarget(this.value)" ontouchstart="startSteer()" onmousedown="startSteer()" ontouchend="resetSteer()" onmouseup="resetSteer()" ontouchcancel="resetSteer()" onmouseleave="resetSteer()">\
            <span>R</span>\
        </div>\
        <button onmousedown="fetch('/api/horn', \{method:'POST'\})" ontouchstart="fetch('/api/horn', \{method:'POST'\})" style="margin-top: 25px; width: 100%; height: 50px; border-radius: 25px; background: rgba(255,0,0,0.2); border: 2px solid red; color: red; font-weight: bold; font-size: 16px; cursor: pointer; pointer-events: auto; box-shadow: 0 0 10px red;">
\f1 \uc0\u55357 \u57000 
\f0  HORN</button>\
    </div>\
\
    <div id="minimap_container"><div id="map"></div></div>\
    \
    <div class="bottom-stats" id="ui_gps">\
        <div><span style="color:#aaa;">SPD:</span> <span id="gps_speed">--</span></div>\
        <div><span style="color:#aaa;">ODO:</span> <span id="gps_dist">--</span></div>\
        <div><span style="color:#aaa;">ALT:</span> <span id="gps_alt">--</span></div>\
        <div><span style="color:#aaa;">SAT:</span> <span id="gps_sats">0</span></div>\
        <div><span style="color:#aaa;">STR:</span> <span id="gps_street" style="max-width:280px; display:inline-block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; vertical-align:bottom;">--</span></div>\
    </div>\
\
    <div id="legal-modal" class="modal" style="z-index: 300;">\
        <div class="modal-content" style="max-width: 400px; text-align: center; border-color: yellow;">\
            <h2 style="color: yellow; margin-top: 0;">
\f1 \uc0\u9888 \u65039 
\f0  CONSTRUCTION / WARNING</h2>\
            <p style="color: #fff; font-size: 14px;">This drone is a high-speed vehicle and your own responsibility. Ensure you are operating it in a safe, legal environment to avoid injury or property damage.</p>\
            <button class="modal-btn" style="background: rgba(255,255,0,0.2); color: yellow; border-color: yellow; margin-top: 15px;" onclick="acceptLegal()">I AGREE (ACCEPT RESPONSIBILITY)</button>\
        </div>\
    </div>\
\
    <div id="loading-modal" class="modal" style="z-index: 250;">\
        <div class="modal-content" style="max-width: 300px; text-align: center;">\
            <div style="margin: 20px auto; width: 40px; height: 40px; border: 4px solid #0f0; border-top: 4px solid transparent; border-radius: 50%; animation: spin 1s linear infinite;"></div>\
            <p style="font-size: 14px;">Detecting USB Microcontrollers...</p>\
            <button class="modal-btn" style="border-color:#aaa; color:#aaa; margin-top: 15px;" onclick="skipLoading()">IGNORE / CONTINUE WITHOUT</button>\
        </div>\
    </div>\
\
    <div id="startup-modal" class="modal" style="z-index: 200;">\
        <div class="modal-content" style="max-width: 300px; text-align: center;">\
            <h3 style="margin:0 0 10px 0;">SYSTEM STARTUP</h3>\
            <div>Enter current battery %</div>\
            <input type="number" id="startup_calib_pct" value="100" min="0" max="100" placeholder="100" oninput="this.value = this.value.replace(/[^0-9]/g, ''); if(this.value>100)this.value=100;" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:10px; border-radius:8px; width: 80px; margin: 15px auto; text-align:center; font-size: 18px; outline: none; display:block;">\
            <div style="font-size: 10px; color: #aaa; margin-bottom: 15px;">Send '0' to wipe.<br>Leave blank to skip.</div>\
            <button class="modal-btn" style="width: 100%;" onclick="submitStartupCal()">OK</button>\
        </div>\
    </div>\
\
    <div id="settings-modal" class="modal">\
        <div class="modal-content">\
            \
            <div class="tab-header">\
                <button class="tab-btn active" onclick="switchTab('general', this)">DRONE SETTINGS</button>\
                <button class="tab-btn" onclick="switchTab('battery', this)">BATTERY</button>\
                <button class="tab-btn" onclick="switchTab('mcu', this)">MICROCONTROLLERS</button>\
                <button class="tab-btn" onclick="switchTab('network', this)">NETWORK</button>\
                <button class="tab-btn" onclick="switchTab('audio', this)">AUDIO & BT</button>\
                <button class="tab-btn" onclick="switchTab('personal_tunnel', this)">FLEET TUNNEL</button>\
            </div>\
\
            <div id="tab_general" class="tab-body active">\
               \
\
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">SYSTEM & SECURITY</div>\
                <div class="modal-row">\
                    <span>PI ROOT PASSWORD:</span>\
                    <input type="text" id="set_pi_password" placeholder="drone786@@" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:5px; border-radius:5px; width: 50%; margin-left: 10px;">\
                </div>\
                <div class="modal-row" style="margin-top: 5px;">\
                    <span>DESKTOP GUI:<br><i style="font-size:10px; color:#aaa;">(Turn OFF for smoother video/CPU performance)</i></span>\
                    <select id="set_gui_enabled" onchange="toggleGUI(this.value)" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:5px; border-radius:5px; width: 40%; margin-left: 10px;">\
                        <option value="false">OFF (FAST)</option><option value="true">ON (SLOW)</option>\
                    </select>\
                </div>\
                <hr>\
\
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">GPS METRICS</div>\
                <div class="modal-row">\
                    <span>UNIT SYSTEM:</span>\
                    <select id="set_unit" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:5px; border-radius:5px; width: 60%; margin-left: 10px;">\
                        <option value="metric">METRIC</option><option value="imperial">IMPERIAL</option>\
                    </select>\
                </div>\
                <hr>\
\
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">STARTUP DEFAULTS</div>\
                <div class="modal-row">\
                    <span>START FWD MAX:</span>\
                    <input type="range" class="std-slider" id="set_fwd" min="1" max="10" oninput="document.getElementById('sv_fwd').innerText=this.value">\
                    <span class="set-val" id="sv_fwd"></span>\
                </div>\
                <div class="modal-row">\
                    <span>START REV MAX:</span>\
                    <input type="range" class="std-slider" id="set_rev" min="1" max="10" oninput="document.getElementById('sv_rev').innerText=this.value">\
                    <span class="set-val" id="sv_rev"></span>\
                </div>\
                \
                <hr>\
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">STEER CALIBRATION</div>\
                <div class="modal-row">\
                    <span>HARDWARE LEFT WALL:</span>\
                    <input type="range" class="std-slider" id="set_abs_l" min="50" max="89" step="0.5" oninput="document.getElementById('sv_abs_l').innerText=this.value; fetch('/steer/set_walls?l='+this.value+'&r='+document.getElementById('set_abs_r').value);">\
                    <span class="set-val" id="sv_abs_l">50.0</span>\
                </div>\
                <div class="modal-row">\
                    <span>HARDWARE RIGHT WALL:</span>\
                    <input type="range" class="std-slider" id="set_abs_r" min="91" max="130" step="0.5" oninput="document.getElementById('sv_abs_r').innerText=this.value; fetch('/steer/set_walls?l='+document.getElementById('set_abs_l').value+'&r='+this.value);">\
                    <span class="set-val" id="sv_abs_r">130.0</span>\
                </div>\
                <div class="modal-row">\
                    <span>ADJUST CENTER TUNE:</span>\
                    <input type="range" class="std-slider" id="set_center" min="50" max="130" step="0.5" oninput="testCenterOffset(this.value)">\
                    <span class="set-val" id="sv_center">90.0</span>\
                </div>\
                <div class="modal-row">\
                    <span>MAX LEFT TURN %:</span>\
                    <input type="range" class="std-slider" id="set_max_l" min="0" max="100" step="5" oninput="document.getElementById('sv_max_l').innerText=this.value+'%'">\
                    <span class="set-val" id="sv_max_l"></span>\
                </div>\
                <div class="modal-row">\
                    <span>MAX RIGHT TURN %:</span>\
                    <input type="range" class="std-slider" id="set_max_r" min="0" max="100" step="5" oninput="document.getElementById('sv_max_r').innerText=this.value+'%'">\
                    <span class="set-val" id="sv_max_r"></span>\
                </div>\
\
                <hr>\
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">HUD TRANSPARENCY</div>\
                <div class="modal-row">\
                    <span>SENSOR BAR OPACITY:</span>\
                    <input type="range" class="std-slider" id="set_op_sens" min="5" max="100" step="5" oninput="document.getElementById('sv_op_sens').innerText=this.value+'%'">\
                    <span class="set-val" id="sv_op_sens"></span>\
                </div>\
                <div class="modal-row">\
                    <span>JOYSTICKS OPACITY:</span>\
                    <input type="range" class="std-slider" id="set_op_ctrl" min="5" max="100" step="5" oninput="document.getElementById('sv_op_ctrl').innerText=this.value+'%'">\
                    <span class="set-val" id="sv_op_ctrl"></span>\
                </div>\
\
                <div class="btn-row">\
                    <button class="modal-btn" onclick="closeModal()">CANCEL</button>\
                    <button class="modal-btn" style="background: rgba(0,255,0,0.3);" onclick="saveSettings()">SAVE & APPLY</button>\
                </div>\
            </div>\
\
            <div id="tab_battery" class="tab-body">\
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">SMART BATTERY CONFIG</div>\
                <div class="modal-row">\
                    <span>CHEMISTRY:</span>\
                    <select id="set_b_type" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:5px; border-radius:5px; width: 50%; margin-left: 10px;">\
                        <option value="lipo">LiPo (2S)</option><option value="nimh">NiMH</option>\
                    </select>\
                </div>\
                <div class="modal-row" style="margin-top: 5px;">\
                    <span>PARALLEL PACKS:</span>\
                    <select id="set_b_count" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:5px; border-radius:5px; width: 50%; margin-left: 10px;">\
                        <option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option>\
                    </select>\
                </div>\
                <div class="modal-row" style="margin-top: 5px;">\
                    <span>mAh (PER PACK):</span>\
                    <input type="number" id="set_b_mah" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:5px; border-radius:5px; width: 60px; margin-left: 10px; text-align:center;">\
                </div>\
                <div style="font-size: 10px; color: #aaa; margin-top: 15px; text-align: center;">\
                    The battery percentage in the HUD dynamically calculates voltage sag based on live Amp draw, chemistry limits, parallel packs, and total mAh.\
                </div>\
                <div class="btn-row" style="margin-top: 15px;">\
                    <button class="modal-btn" style="background: rgba(0,255,0,0.3);" onclick="saveSettings()">SAVE BATTERY</button>\
                </div>\
            </div>\
\
            <div id="tab_mcu" class="tab-body">\
                <button class="modal-btn" style="border-color:#f00; color:#f00; margin-bottom:15px; width:100%; background:rgba(255,0,0,0.1);" onclick="restartPilot()">
\f1 \uc0\u55357 \u56580 
\f0  RESTART DRONE BRAIN</button>\
\
                <div style="background: rgba(0,255,0,0.15); border: 1px solid #0f0; border-radius: 8px; padding: 10px; text-align: center; font-weight: bold; margin-bottom: 15px;">\
                    <div style="margin-bottom: 5px; font-size: 11px;">DRIVE MEM: FWD <span id="esp_f" style="color:#fff;">--</span> | REV <span id="esp_r" style="color:#fff;">--</span> | CAL: <span id="esp_c" style="color:#fff;">--</span>% | FS: <span id="esp_fs" style="color:#fff;">--</span>s | RUN: <span id="top_up_drive" style="color:#0f0;">--</span></div>\
                    <div style="margin-bottom: 5px; font-size: 11px;">STEER MEM: L <span id="esp_al" style="color:#fff;">--</span> | R <span id="esp_ar" style="color:#fff;">--</span> | C <span id="esp_ctr" style="color:#fff;">--</span> | RUN: <span id="top_up_steer" style="color:#0f0;">--</span></div>\
                    <div style="font-size: 11px; color:#aaa; border-top: 1px solid rgba(0,255,0,0.2); padding-top: 5px;">\
                        DETECTED PORTS -> DRIVE: <span id="ui_dp" style="color:#0af;">--</span> | STEER: <span id="ui_sp" style="color:#0af;">--</span>\
                    </div>\
                </div>\
\
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">USB PORT BINDING</div>\
