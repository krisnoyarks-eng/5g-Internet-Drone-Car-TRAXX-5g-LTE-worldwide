                </div>\
                \
                <button class="modal-btn" style="width:100%;" onclick="scanWifi()">SCAN FOR NETWORKS</button>\
                <div id="wifi_list" style="margin-top:15px; max-height:250px; overflow-y:auto;"></div>\
            </div>\
\
            <div id="tab_audio" class="tab-body">\
                <div style="text-align:center; font-weight:bold; margin-bottom:5px;">HORN SELECTION</div>\
                <div class="modal-row">\
                    <span>HORN TYPE:</span>\
                    <select id="set_horn_type" style="background:rgba(0,0,0,0.5); color:#0f0; border:1px solid #0f0; padding:5px; border-radius:5px; width: 55%; margin-left: 10px;">\
